{
  "manifest_version": 3,
  "name": "OpenAlex Author Finder",
  "version": "1.1",
  "description": "Find ML engineering candidates from academic literature using OpenAlex and GitHub",
  "action": {
    "default_title": "OpenAlex Author Finder",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": [
    "storage",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
